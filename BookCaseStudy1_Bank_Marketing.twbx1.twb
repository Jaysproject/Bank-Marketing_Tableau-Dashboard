      <column caption='Previous Contact Status' datatype='string' name='[Calculation_0046655904882693]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [pdays] = -1 THEN &quot;Not previously contacted&quot;&#10;ELSE &quot;Previously contacted&quot;&#10;END' />
      </column>
      <column caption='Number of Records' datatype='integer' name='[Calculation_0046655905681414]' role='measure' type='quantitative'>
