      </column>
      <column caption='Age Band' datatype='string' name='[Calculation_0046656056844296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt; 25 THEN &quot;18-24&quot;&#10;ELSEIF [age] &lt; 35 THEN &quot;25-34&quot;&#10;ELSEIF [age] &lt; 45 THEN &quot;35-44&quot;&#10;ELSEIF [age] &lt; 55 THEN &quot;45-54&quot;&#10;ELSEIF [age] &lt; 65 THEN &quot;55-64&quot;&#10;ELSE &quot;65+&quot;&#10;END' />
      </column>
      <column caption='Client Count' datatype='integer' name='[Calculation_0046656057208841]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Month Number' datatype='integer' name='[Calculation_0046656062574602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [month]&#10;WHEN &quot;jan&quot; THEN 1&#10;WHEN &quot;feb&quot; THEN 2&#10;WHEN &quot;mar&quot; THEN 3&#10;WHEN &quot;apr&quot; THEN 4&#10;WHEN &quot;may&quot; THEN 5&#10;WHEN &quot;jun&quot; THEN 6&#10;WHEN &quot;jul&quot; THEN 7&#10;WHEN &quot;aug&quot; THEN 8&#10;WHEN &quot;sep&quot; THEN 9&#10;WHEN &quot;oct&quot; THEN 10&#10;WHEN &quot;nov&quot; THEN 11&#10;WHEN &quot;dec&quot; THEN 12&#10;END' />
      </column>
      <column caption='Campaign Band' datatype='string' name='[Calculation_0046656062791691]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [campaign] = 1 THEN &quot;1 contact&quot;&#10;ELSEIF [campaign] = 2 THEN &quot;2 contacts&quot;&#10;ELSEIF [campaign] = 3 THEN &quot;3 contacts&quot;&#10;ELSEIF [campaign] &lt;= 5 THEN &quot;4-5 contacts&quot;&#10;ELSE &quot;6+ contacts&quot;&#10;END' />
      </column>
      <column caption='Prior Contact Status' datatype='string' name='[Calculation_0046656063488012]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [pdays] = -1 THEN &quot;Never previously contacted&quot;&#10;ELSE &quot;Previously contacted&quot;&#10;END' />
      </column>
      <column caption='Deposit Flag' datatype='integer' name='[Calculation_0046656067719181]' role='measure' type='quantitative'>
