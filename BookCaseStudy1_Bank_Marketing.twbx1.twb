        <calculation class='tableau' formula='IF [duration] &lt; 60 THEN &quot;&lt;1 min&quot;&#10;ELSEIF [duration] &lt; 180 THEN &quot;1-3 min&quot;&#10;ELSEIF [duration] &lt; 300 THEN &quot;3-5 min&quot;&#10;ELSEIF [duration] &lt; 600 THEN &quot;5-10 min&quot;&#10;ELSEIF [duration] &lt; 1200 THEN &quot;10-20 min&quot;&#10;ELSE &quot;20+ min&quot;&#10;END' />
